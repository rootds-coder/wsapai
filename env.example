# Example environment variables for Open Truly Chat
OPENAI_API_KEY=your-openai-api-key-here
WHATSAPP_SESSION_PATH=./session
BROWSER_PATH=/usr/bin/brave-browser
PORT=3000

# Security Settings (REQUIRED FOR PRODUCTION)
ADMIN_PASSWORD=change-this-to-a-strong-password
SESSION_SECRET=change-this-to-a-random-secret-string
NODE_ENV=production

# Optional: CORS origin (use your domain in production)
# ALLOWED_ORIGIN=https://your-domain.com

# Keep-Alive Settings (for Render free tier - prevents sleeping)
KEEP_ALIVE_ENABLED=true
KEEP_ALIVE_INTERVAL=840000
# APP_URL will be auto-detected on Render, but you can set it manually:
# APP_URL=https://your-app.onrender.com
